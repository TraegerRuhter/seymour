# Optional: enables the AI fallback for recipe parsing when a page has no
# schema.org Recipe structured data. Used server-side only (never shipped to
# the client). Without it, URL import still works for structured-data pages —
# the majority of recipe sites.
OPENAI_API_KEY=

# Optional: enables the "Discover" tab on Add a recipe — search by what you
# want ("chicken", "quick vegetarian dinners") instead of pasting a URL.
# Backed by Spoonacular's recipe search API (a real recipe index, not a
# guess), free tier: 150 points/day at spoonacular.com/food-api. Without it,
# Discover shows a clear "needs an API key" message instead of failing
# silently; URL and manual import are unaffected either way.
SPOONACULAR_API_KEY=

# Reader-proxy fallback for recipe sites that block direct server-side fetches
# (Cloudflare-protected sites like Allrecipes/NYT reject datacenter IPs no
# matter the headers). A blocked page is routed through this proxy, which
# fetches it from its own infrastructure and returns the HTML for Seymour to
# parse. Only used as a fallback — reachable sites never touch it.
#
# Defaults to Jina AI Reader (https://r.jina.ai/{url}, free tier) when unset.
# Override with your own {url} template, or set to "off" to disable all
# third-party calls and keep Seymour fully self-contained.
RECIPE_READER_PROXY=

# Optional: enables accounts + cross-device sync. Both come from a Supabase
# project's Project Settings → API page. Run supabase/schema.sql in that
# project's SQL editor first. Leaving these unset is fully supported — Seymour
# works exactly as it does today, entirely local to the browser, with no
# sign-in prompt anywhere. Safe to expose to the client (NEXT_PUBLIC_*): the
# anon key only grants what each table's row-level security policy allows.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: backs the API rate limiter with Upstash Redis so the limit is
# shared across every server instance under real traffic, instead of each
# instance keeping its own separate in-memory counter (which effectively
# multiplies the real limit once there's more than one instance running).
# These are the names Vercel's Storage → Upstash integration sets
# automatically if you add it through the Vercel dashboard; grab them from
# your Upstash project's REST API section if you set it up directly instead.
# Leaving these unset is fully supported — the rate limiter just falls back
# to the in-memory counter, which is fine for local dev and a single-instance
# deployment.
KV_REST_API_URL=
KV_REST_API_TOKEN=
