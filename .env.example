# Optional: enables the AI fallback for recipe parsing when a page has no
# schema.org Recipe structured data. Used server-side only (never shipped to
# the client).
OPENAI_API_KEY=

# Optional: reader-proxy fallback for recipe sites that block direct
# server-side fetches (Cloudflare-protected sites like Allrecipes/NYT reject
# datacenter IPs no matter the headers). When set, a blocked page is routed
# through this proxy, which fetches it from its own infrastructure and returns
# the HTML for Seymour to parse. Use {url} as the target placeholder.
# Leave blank to keep Seymour fully self-contained (no third-party calls).
# Example (Jina AI Reader, free tier): https://r.jina.ai/{url}
RECIPE_READER_PROXY=
